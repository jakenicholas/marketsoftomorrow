<script>
const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.12,rootMargin:"0px 0px -8% 0px"});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
const geoObs=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.querySelectorAll('.bar-fill').forEach(f=>{f.style.width=f.dataset.w+'%';});geoObs.unobserve(e.target);}});},{threshold:.3});
const barsEl=document.querySelector('.bars'); if(barsEl) geoObs.observe(barsEl);
let last=0; const nav=document.getElementById('nav');
addEventListener('scroll',()=>{const y=scrollY; nav.style.transform=(y>last&&y>300)?'translateY(-100%)':'translateY(0)'; last=y;});
(function(){
  const svg=document.getElementById('growthsvg'); if(!svg) return;
  const W=1000,H=320, pad={l:40,r:30,t:30,b:40};
  const data=[{x:'2023',y:2},{x:'2024',y:5},{x:'2025',y:10},{x:'2026 (proj.)',y:20}];
  const maxY=22;
  const px=i=>pad.l+i*((W-pad.l-pad.r)/(data.length-1));
  const py=v=>H-pad.b-(v/maxY)*(H-pad.t-pad.b);
  const ns='http://www.w3.org/2000/svg';
  [0,5,10,15,20].forEach(v=>{const y=py(v);const l=document.createElementNS(ns,'line');l.setAttribute('x1',pad.l);l.setAttribute('x2',W-pad.r);l.setAttribute('y1',y);l.setAttribute('y2',y);l.setAttribute('class','gridline');svg.appendChild(l);const t=document.createElementNS(ns,'text');t.setAttribute('x',0);t.setAttribute('y',y+4);t.setAttribute('class','axislab');t.textContent=v;svg.appendChild(t);});
  let d='',area='M'+px(0)+','+(H-pad.b);
  data.forEach((p,i)=>{d+=(i?'L':'M')+px(i)+','+py(p.y);area+='L'+px(i)+','+py(p.y);});
  area+='L'+px(data.length-1)+','+(H-pad.b)+'Z';
  const grad=document.createElementNS(ns,'linearGradient');grad.setAttribute('id','ag');grad.setAttribute('x1','0');grad.setAttribute('y1','0');grad.setAttribute('x2','0');grad.setAttribute('y2','1');grad.innerHTML='<stop offset="0%" stop-color="#1FDF67" stop-opacity=".28"/><stop offset="100%" stop-color="#1FDF67" stop-opacity="0"/>';svg.appendChild(grad);
  const ap=document.createElementNS(ns,'path');ap.setAttribute('d',area);ap.setAttribute('fill','url(#ag)');ap.setAttribute('opacity','0');svg.appendChild(ap);
  const lp=document.createElementNS(ns,'path');lp.setAttribute('d',d);lp.setAttribute('fill','none');lp.setAttribute('stroke','#1FDF67');lp.setAttribute('stroke-width','3.5');lp.setAttribute('stroke-linecap','round');lp.setAttribute('stroke-linejoin','round');svg.appendChild(lp);
  const len=lp.getTotalLength();lp.style.strokeDasharray=len;lp.style.strokeDashoffset=len;lp.style.transition='stroke-dashoffset 1.6s cubic-bezier(.22,1,.36,1)';
  data.forEach((p,i)=>{const c=document.createElementNS(ns,'circle');c.setAttribute('cx',px(i));c.setAttribute('cy',py(p.y));c.setAttribute('r',5.5);c.setAttribute('fill','#070807');c.setAttribute('stroke','#1FDF67');c.setAttribute('stroke-width','3');c.setAttribute('opacity','0');c.style.transition='opacity .4s '+(0.6+i*.22)+'s';svg.appendChild(c);c._show=()=>c.setAttribute('opacity','1');const t=document.createElementNS(ns,'text');t.setAttribute('x',px(i));t.setAttribute('y',py(p.y)-16);t.setAttribute('text-anchor','middle');t.setAttribute('class','pointlab');t.setAttribute('opacity','0');t.style.transition='opacity .4s '+(0.7+i*.22)+'s';t.textContent=p.y+'M';svg.appendChild(t);t._show=()=>t.setAttribute('opacity','1');const xl=document.createElementNS(ns,'text');xl.setAttribute('x',px(i));xl.setAttribute('y',H-12);xl.setAttribute('text-anchor','middle');xl.setAttribute('class','axislab');xl.textContent=p.x;svg.appendChild(xl);});
  const co=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){lp.style.strokeDashoffset=0;ap.style.transition='opacity 1s .5s';ap.setAttribute('opacity','1');svg.querySelectorAll('circle').forEach(c=>c._show&&c._show());svg.querySelectorAll('text').forEach(t=>t._show&&t._show());co.unobserve(e.target);}});},{threshold:.4});
  co.observe(svg);
})();
</script>
