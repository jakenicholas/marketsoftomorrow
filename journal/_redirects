# Cloudflare Pages redirects — old Wix paths → new journal equivalents.
# Article URLs (/post/<slug>) are unchanged and need no redirect.
# Format: <from>  <to>  <status>

# Wix blog index → journal home
/blog            /            301
/blog/*          /            301

# Iconic list pages (best-guess old Wix slugs → new section pages).
# Harmless if a source never existed; adjust to your real old URLs.
/the-iconic-hotel-list        /hotels/        301
/the-iconic-golf-list         /golf/          301
/the-iconic-restaurant-list   /restaurants/   301
/iconic-hotels                /hotels/        301
/iconic-golf                  /golf/          301
/iconic-restaurants           /restaurants/   301

# Media kit (lives on the map deploy for now)
/media-kit       /media/    301

# Project detail pages moved from /map/projects/<slug>/ to the site root
# /projects/<slug>/. 301 the old (indexed) paths so links + SEO carry over.
/map/projects/*      /projects/:splat    301

# One-off slug typo fix — old indexed URL stays alive via 301.
/projects/kempinksi-residences/  /projects/kempinski-residences/  301
/projects/kempinksi-residences   /projects/kempinski-residences/  301

# "Eateries" type was retired — projects with multiple types are still
# represented under their other category pages; the only project that
# was Eateries-only (Eataly Food Hall) is now Retail. Funnel any old
# indexed `-eateries` URL into the parent city's market page.
/markets/boca-raton-eateries/         /markets/boca-raton/         301
/markets/fort-lauderdale-eateries/    /markets/fort-lauderdale/    301
/markets/jacksonville-eateries/       /markets/jacksonville/       301
/markets/miami-eateries/              /markets/miami/              301
/markets/nashville-eateries/          /markets/nashville/          301
/markets/new-york-city-eateries/      /markets/new-york-city/      301
/markets/riviera-beach-eateries/      /markets/riviera-beach/      301
/markets/saudi-arabia-eateries/       /markets/saudi-arabia/       301
/markets/tampa-eateries/              /markets/tampa/              301
/markets/west-palm-beach-eateries/    /markets/west-palm-beach/    301

# Firm pages moved to a flat /firm/<slug>/ structure (merging firms that are
# both architect + developer into one page). Redirect every old shape:
#   - the previous static location under /map/
#   - the map SPA's in-app pushState URLs (/architects|developers/<slug>/),
#     so reloading or sharing an in-app firm URL lands on the canonical page.
/map/architects/*    /firm/:splat    301
/map/developers/*    /firm/:splat    301
/architects/*        /firm/:splat    301
/developers/*        /firm/:splat    301
